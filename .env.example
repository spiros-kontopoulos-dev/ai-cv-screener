APP_NAME=AI CV Screener API
APP_ENV=development
LOG_LEVEL=INFO

FRONTEND_ORIGIN=http://localhost:5173

OPENAI_API_KEY=

# synthetic-candidate generation.
# The relative path resolves from /app inside the backend container.
CANDIDATE_DATASET_PLAN_PATH=app/dataset/candidate_dataset_plan.json
CANDIDATE_GENERATION_MODEL=gpt-5.4-mini
CANDIDATE_GENERATION_MAX_RETRIES=2
CANDIDATE_GENERATION_TIMEOUT_SECONDS=120
CANDIDATE_GENERATION_MAX_COMPLETION_TOKENS=6000

# Validated JSON consumed later by the deterministic PDF renderer.
CANDIDATE_PROFILES_OUTPUT_PATH=data/candidate_profiles/candidate_profiles.json

# deterministic CV rendering paths.
CANDIDATE_IMAGES_DIRECTORY=data/candidate_images
CV_PDFS_OUTPUT_DIRECTORY=data/cv_pdfs
CV_HTML_PREVIEW_DIRECTORY=data/cv_html
# AI-generated fictional candidate portraits.
PORTRAIT_GENERATION_MODEL=gpt-image-1
PORTRAIT_GENERATION_SIZE=1024x1024
PORTRAIT_GENERATION_QUALITY=medium
PORTRAIT_GENERATION_OUTPUT_COMPRESSION=85
PORTRAIT_GENERATION_MAX_RETRIES=2
PORTRAIT_GENERATION_TIMEOUT_SECONDS=180
PORTRAIT_NORMALIZED_SIZE=512
PORTRAIT_WEBP_QUALITY=88

