# Dependencies are installed inside the Docker image with npm ci.
node_modules

# Vite production output should not be copied into the development image.
dist

# Local environment files must not enter the image.
.env
.env.*
!.env.example

# Git and editor metadata are unnecessary inside the image.
.git
.gitignore
.vscode
.idea

# Operating-system files.
.DS_Store
Thumbs.db